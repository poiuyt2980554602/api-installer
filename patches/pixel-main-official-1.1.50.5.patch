+func resolveUpstreamFirstResponseFailoverTimeout(cfg *config.Config) time.Duration {
+	if cfg == nil {
+		return defaultUpstreamFirstResponseFailoverTimeout
+	}
+	seconds := cfg.Gateway.UpstreamFirstResponseFailoverTimeout
+	if seconds <= 0 {
+		return 0
+	}
+	return time.Duration(seconds) * time.Second
+}
+
+func (s *GatewayService) upstreamFirstResponseFailoverTimeout() time.Duration {
