+type subsiteProxyResult struct {
+	StatusCode                int
+	LatencyMS                 int64
+	ResponseBytes             int64
+	ClientError               bool
+	RetryableSelectionFailure bool
+	SelectionFailureCode      string
+}
+
+type subsiteHTTPStatusError struct {
+	statusCode int
