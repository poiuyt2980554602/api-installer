+}
+
+func (e *subsiteHTTPStatusError) Error() string {
+	if e == nil {
+		return "subsite returned an error status"
+	}
+	if e.body != "" {
+		return fmt.Sprintf("subsite returned %d: %s", e.statusCode, e.body)
