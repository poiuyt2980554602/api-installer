+  try {
+    const result = await adminAPI.subsites.updateForwardMode(forwardModeForm.value)
+    forwardModeForm.value = result.mode
+    await loadStats()
+  } finally {
+    modeSaving.value = false
+  }
+}
+
+async function autoDistribute(): Promise<void> {
+  distributing.value = true
+  distributionResult.value = null
+  try {
+    distributionResult.value = await adminAPI.subsites.autoDistributeLeases({
+      group_id: distributionForm.group_id || undefined,
+      platform: distributionForm.platform || undefined,
+      limit: normalizeNonNegativeInteger(distributionForm.limit),
+      ttl_seconds: Math.max(1, normalizeNonNegativeInteger(distributionTTLHours.value)) * 3600,
+      dry_run: distributionForm.dry_run,
+      include_unhealthy: distributionForm.include_unhealthy
+    })
+    await loadStats()
+  } finally {
+    distributing.value = false
+  }
+}
+
+async function releaseInvalid(): Promise<void> {
+  distributing.value = true
+  try {
+    const result = await adminAPI.subsites.releaseInvalidLeases()
+    distributionResult.value = {
+      assigned: 0,
+      skipped: 0,
+      failed: 0,
+      candidates: 0,
+      target_subsites: 0,
+      expired_leases: 0,
+      released_invalid_leases: result.released_invalid_leases,
+      dry_run: false,
+      by_subsite: []
+    }
+    await loadStats()
+  } finally {
+    distributing.value = false
+  }
+}
+
+async function saveAffinity(): Promise<void> {
+  if (!affinityForm.affinity_key || !affinityForm.subsite_id) return
+  affinitySaving.value = true
+  try {
+    await adminAPI.subsites.upsertForwardAffinity({
+      affinity_key: affinityForm.affinity_key,
+      affinity_type: 'manual',
+      subsite_id: affinityForm.subsite_id,
+      lease_id: affinityForm.lease_id || undefined,
+      account_id: affinityForm.account_id || undefined,
+      api_key_id: affinityForm.api_key_id || undefined,
+      ttl_seconds: Math.max(1, normalizeNonNegativeInteger(affinityTTLHours.value)) * 3600,
+      locked: affinityForm.locked
+    })
+    resetAffinityForm()
+    await loadAffinities()
+  } finally {
+    affinitySaving.value = false
+  }
+}
+
+async function deleteAffinity(id: number): Promise<void> {
+  await adminAPI.subsites.deleteForwardAffinity(id)
+  await loadAffinities()
+}
+
+function resetAffinityForm(): void {
+  Object.assign(affinityForm, {
+    affinity_key: '',
+    subsite_id: '',
+    lease_id: '',
+    account_id: 0,
+    api_key_id: 0,
+    locked: true
+  })
+  affinityTTLHours.value = 24
+}
+
+function normalizeForwardMode(value: string): SubsiteForwardMode {
+  if (value === 'local' || value === 'direct' || value === 'forward') return value
+  return 'forward'
+}
+
+function normalizeNonNegativeInteger(value: number): number {
+  if (!Number.isFinite(value)) return 0
+  return Math.max(0, Math.floor(value))
+}
+
+function siteStatusLabel(row: SubsiteForwardSiteStat): string {
+  if (row.circuit_open) return '熔断'
+  return ({
+    active: '在线',
+    unhealthy: '异常',
+    maintenance: '维护',
+    disabled: '停用',
+    pending: '待激活'
+  } as Record<string, string>)[row.effective_status || row.status] || row.effective_status || row.status
+}
+
+function siteStatusClass(row: SubsiteForwardSiteStat): string {
+  if (row.circuit_open) return 'badge-danger'
+  return ({
+    active: 'badge-success',
+    unhealthy: 'badge-danger',
+    maintenance: 'badge-warning',
+    disabled: 'badge-gray',
+    pending: 'badge-warning'
+  } as Record<string, string>)[row.effective_status || row.status] || 'badge-gray'
+}
+
+function eventOutcomeClass(outcome: string): string {
+  return ({
+    success: 'badge-success',
+    failed: 'badge-danger',
+    failover: 'badge-warning',
+    fallback: 'badge-warning'
+  } as Record<string, string>)[outcome] || 'badge-gray'
+}
+
+function formatCompact(value: number): string {
+  return new Intl.NumberFormat(undefined, { notation: 'compact', maximumFractionDigits: 1 }).format(value)
+}
+
+function formatPercent(value: number): string {
+  const normalized = value > 1 ? value / 100 : value
+  return `${(normalized * 100).toFixed(1)}%`
+}
+
+function formatCost(value: number): string {
+  return `$${value.toFixed(4)}`
+}
+
+function formatNumber(value: number, digits: number): string {
+  return value.toFixed(digits)
+}
+
+function formatDate(value?: string): string {
+  if (!value) return '-'
+  return new Date(value).toLocaleString()
+}
+
+onMounted(() => {
+  void refreshAll()
+})
+</script>
