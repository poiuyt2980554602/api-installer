+package handler
+
+import (
+	"bufio"
+	"context"
+	"errors"
+	"io"
+	"net/http"
+	"net/http/httptest"
+	"strings"
+	"sync/atomic"
+	"testing"
+	"time"
+
+	"github.com/gin-gonic/gin"
+	"github.com/stretchr/testify/require"
+)
+
+func TestCopySubsiteResponseStreamsBeforeReaderCompletes(t *testing.T) {
+	gin.SetMode(gin.TestMode)
+
+	reader, writer := io.Pipe()
+	firstChunkWritten := make(chan struct{})
+	allowComplete := make(chan struct{})
+
+	router := gin.New()
+	router.GET("/stream", func(c *gin.Context) {
+		_, _ = copySubsiteResponse(c, reader, "text/event-stream")
+	})
+
+	server := httptest.NewServer(router)
+	defer server.Close()
+
+	go func() {
+		_, _ = writer.Write([]byte("data: first\n\n"))
+		close(firstChunkWritten)
+		<-allowComplete
+		_, _ = writer.Write([]byte("data: second\n\n"))
+		_ = writer.Close()
+	}()
+
+	resp, err := http.Get(server.URL + "/stream") //nolint:gosec,noctx
+	require.NoError(t, err)
+	defer resp.Body.Close()
+	defer close(allowComplete)
+
+	require.Equal(t, http.StatusOK, resp.StatusCode)
+	require.Equal(t, "text/event-stream", strings.Split(resp.Header.Get("Content-Type"), ";")[0])
+
+	select {
+	case <-firstChunkWritten:
+	case <-time.After(time.Second):
+		t.Fatal("test writer did not write the first chunk")
+	}
+
+	lineCh := make(chan string, 1)
+	go func() {
+		scanner := bufio.NewScanner(resp.Body)
+		for scanner.Scan() {
+			line := scanner.Text()
+			if strings.HasPrefix(line, "data:") {
+				lineCh <- line
+				return
+			}
+		}
+		lineCh <- ""
+	}()
+
+	select {
+	case line := <-lineCh:
+		require.Equal(t, "data: first", line)
+	case <-time.After(time.Second):
+		t.Fatal("first SSE chunk was not flushed before the reader completed")
+	}
+}
+
+func TestSubsiteRouteSnapshotStoreCachesAndFallsBackToStaleSnapshot(t *testing.T) {
+	store := newSubsiteRouteSnapshotStore(20*time.Millisecond, time.Second)
+	var loads atomic.Int32
+	first := &subsiteRouteSnapshot{loadedAt: time.Now()}
+
+	load := func(context.Context) (*subsiteRouteSnapshot, error) {
+		if loads.Add(1) == 1 {
+			return first, nil
+		}
+		return nil, errors.New("database temporarily unavailable")
+	}
+
+	got, err := store.Get(context.Background(), load)
+	require.NoError(t, err)
+	require.Same(t, first, got)
+
+	got, err = store.Get(context.Background(), load)
+	require.NoError(t, err)
+	require.Same(t, first, got)
+	require.Equal(t, int32(1), loads.Load())
+
+	time.Sleep(25 * time.Millisecond)
+	got, err = store.Get(context.Background(), load)
+	require.NoError(t, err)
+	require.Same(t, first, got)
+	require.Equal(t, int32(2), loads.Load())
+}
