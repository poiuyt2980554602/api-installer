+func (a *Account) quotaExhaustedSchedulingStateAt(now time.Time) (bool, string, *time.Time) {
+	if a == nil {
+		return false, "", nil
+	}
+	if a.IsAPIKeyOrBedrock() {
+		if exhausted, reason, until := a.apiKeyQuotaExhaustedSchedulingStateAt(now); exhausted {
+			return true, reason, until
+		}
+	}
+	if a.Platform == PlatformOpenAI && a.IsOAuth() {
+		if exhausted, reason, until := a.codexQuotaExhaustedSchedulingStateAt(now); exhausted {
+			return true, reason, until
+		}
+	}
+	return false, "", nil
+}
+
+func (a *Account) apiKeyQuotaExhaustedSchedulingStateAt(now time.Time) (bool, string, *time.Time) {
+	if limit := a.GetQuotaLimit(); limit > 0 && a.GetQuotaUsed() >= limit {
+		return true, "total account quota exhausted", nil
+	}
+	if limit := a.GetQuotaDailyLimit(); limit > 0 {
+		start := a.getExtraTime("quota_daily_start")
+		if !a.IsDailyQuotaPeriodExpiredAt(now) && a.GetQuotaDailyUsed() >= limit {
+			return true, "daily account quota exhausted", ptrIfFuture(a.nextDailyQuotaResetAt(start, now), now)
+		}
+	}
+	if limit := a.GetQuotaWeeklyLimit(); limit > 0 {
+		start := a.getExtraTime("quota_weekly_start")
+		if !a.IsWeeklyQuotaPeriodExpiredAt(now) && a.GetQuotaWeeklyUsed() >= limit {
+			return true, "weekly account quota exhausted", ptrIfFuture(a.nextWeeklyQuotaResetAt(start, now), now)
+		}
+	}
+	return false, "", nil
+}
+
+func (a *Account) codexQuotaExhaustedSchedulingStateAt(now time.Time) (bool, string, *time.Time) {
+	if a.GetCodex5hUsedPercent() >= 100 {
+		resetAt := a.GetCodex5hResetAt()
+		if resetAt.IsZero() || now.Before(resetAt) {
+			return true, "codex 5h quota exhausted", ptrIfFuture(resetAt, now)
+		}
+	}
+	if a.GetCodex7dUsedPercent() >= 100 {
+		resetAt := a.GetCodex7dResetAt()
+		if resetAt.IsZero() || now.Before(resetAt) {
+			return true, "codex 7d quota exhausted", ptrIfFuture(resetAt, now)
+		}
+	}
+	return false, "", nil
+}
+
+func (a *Account) nextDailyQuotaResetAt(start time.Time, now time.Time) time.Time {
+	if a.GetQuotaDailyResetMode() == "fixed" {
+		tz, err := time.LoadLocation(a.GetQuotaResetTimezone())
+		if err != nil {
+			tz = time.UTC
+		}
+		return nextFixedDailyReset(a.GetQuotaDailyResetHour(), tz, now)
+	}
+	if start.IsZero() {
+		return time.Time{}
+	}
+	return start.Add(24 * time.Hour)
+}
+
+func (a *Account) nextWeeklyQuotaResetAt(start time.Time, now time.Time) time.Time {
+	if a.GetQuotaWeeklyResetMode() == "fixed" {
+		tz, err := time.LoadLocation(a.GetQuotaResetTimezone())
+		if err != nil {
+			tz = time.UTC
+		}
+		return nextFixedWeeklyReset(a.GetQuotaWeeklyResetDay(), a.GetQuotaWeeklyResetHour(), tz, now)
+	}
+	if start.IsZero() {
+		return time.Time{}
+	}
+	return start.Add(7 * 24 * time.Hour)
+}
+
+func cloneTimePtr(in *time.Time) *time.Time {
+	if in == nil {
+		return nil
+	}
+	out := *in
+	return &out
+}
+
+func ptrIfFuture(value time.Time, now time.Time) *time.Time {
+	if value.IsZero() || !now.Before(value) {
+		return nil
+	}
+	out := value
+	return &out
+}
