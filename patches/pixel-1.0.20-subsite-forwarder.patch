+				LimitedUntil: schedulingState.LimitedUntil,
+				Error:        schedulingState.Reason,
+			})
+			continue
+		}
+		if !isAutoDistributeAccountCandidate(account) {
+			result.Skipped++
+			result.Items = appendAutoDistributeItem(result.Items, AutoDistributeAccountLeaseResult{
+				AccountID: account.ID,
+				Platform:  account.Platform,
+				Status:    "skipped",
+				Reason:    "not_public_pool",
+				Error:     "account is not in the public auto-distribution pool",
+			})
+			continue
+		}
+		if _, exists := effective[account.ID]; exists {
+			result.Skipped++
+			result.Items = appendAutoDistributeItem(result.Items, AutoDistributeAccountLeaseResult{
+				AccountID: account.ID,
+				Platform:  account.Platform,
+				Status:    "skipped",
+				Reason:    "already_leased",
+				Error:     "account already has active lease",
+			})
+			continue
+		}
+		groupID, ok := pickAutoDistributeGroupID(account, input.GroupID, input.Platform)
+		if !ok {
+			result.Skipped++
+			result.Items = appendAutoDistributeItem(result.Items, AutoDistributeAccountLeaseResult{
+				AccountID: account.ID,
+				Platform:  account.Platform,
+				Status:    "skipped",
+				Reason:    "no_matching_group",
+				Error:     "no active matching group",
+			})
+			continue
+		}
+		target := pickLeastLoadedSubsite(targets)
+		if target == nil {
+			result.Skipped++
+			break
+		}
+		item := AutoDistributeAccountLeaseResult{
+			AccountID: account.ID,
+			GroupID:   groupID,
+			Platform:  account.Platform,
+			SubsiteID: target.Stat.SubsiteID,
+		}
+		if input.DryRun {
+			item.Status = "planned"
+			result.Assigned++
+			target.PlannedLeases++
+			assignedBySubsite[target.Stat.SubsiteID]++
+			result.Items = appendAutoDistributeItem(result.Items, item)
+			continue
+		}
+		lease := &AccountLease{
+			LeaseID:        "lease_" + strings.ReplaceAll(uuid.NewString(), "-", ""),
+			SubsiteID:      target.Stat.SubsiteID,
+			AccountID:      account.ID,
+			GroupID:        groupID,
+			Platform:       account.Platform,
+			Status:         AccountLeaseStatusActive,
+			MaxConcurrency: clampNonNegativeInt(input.MaxConcurrency),
+			MaxRequests:    clampNonNegativeInt(input.MaxRequests),
+			MaxTokens:      maxInt64(0, input.MaxTokens),
+			AssignedAt:     time.Now(),
+			ExpiresAt:      expiresAt,
+		}
+		if err := s.leaseRepo.Create(ctx, lease); err != nil {
+			if errors.Is(err, ErrAccountLeaseConflict) {
+				result.Skipped++
+				effective[account.ID] = struct{}{}
+				item.Status = "skipped"
+				item.Reason = "already_leased"
+				item.Error = "account already has active lease"
+			} else {
+				result.Failed++
+				item.Status = "failed"
+				item.Reason = "create_failed"
+				item.Error = err.Error()
+			}
+			result.Items = appendAutoDistributeItem(result.Items, item)
+			continue
+		}
+		effective[account.ID] = struct{}{}
+		item.LeaseID = lease.LeaseID
+		item.Status = "assigned"
+		result.Assigned++
+		target.PlannedLeases++
+		assignedBySubsite[target.Stat.SubsiteID]++
+		result.Items = appendAutoDistributeItem(result.Items, item)
+	}
+	result.Candidates = int64(len(accounts))
+	for i := range result.BySubsite {
+		result.BySubsite[i].Assigned = assignedBySubsite[result.BySubsite[i].SubsiteID]
+		result.BySubsite[i].ActiveLeases += result.BySubsite[i].Assigned
+	}
+	return result, nil
+}
