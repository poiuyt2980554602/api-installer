+func appendAutoDistributeItem(items []AutoDistributeAccountLeaseResult, item AutoDistributeAccountLeaseResult) []AutoDistributeAccountLeaseResult {
+	if len(items) >= 100 {
+		return items
+	}
+	return append(items, item)
+}
