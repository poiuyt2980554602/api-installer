+func TestAccountLeaseServiceAutoDistributeAssignsLowestLoadSubsite(t *testing.T) {
+	now := time.Now()
+	group := &Group{ID: 10, Platform: PlatformOpenAI, Status: StatusActive, Scope: GroupScopePublic}
+	leaseRepo := &autoDistributionLeaseRepoStub{
+		activeBySubsite: map[string][]AccountLease{
+			"busy": {
+				{LeaseID: "lease_busy_1", AccountID: 9001, ExpiresAt: now.Add(time.Hour), Status: AccountLeaseStatusActive},
+				{LeaseID: "lease_busy_2", AccountID: 9002, ExpiresAt: now.Add(time.Hour), Status: AccountLeaseStatusActive},
+			},
+			"idle": {},
+		},
+		effectiveIDs:    []int64{9001, 9002},
+		expired:         1,
+		releasedInvalid: 2,
+	}
+	svc := NewAccountLeaseService(
+		leaseRepo,
+		&autoDistributionSubsiteRepoStub{sites: []SubsiteForwardSiteStat{
+			{
+				SubsiteID:       "busy",
+				Name:            "Busy",
+				Status:          SubsiteStatusActive,
+				HealthScore:     100,
+				LastHeartbeatAt: &now,
+				ActiveRequests:  8,
+				QueuedUsage:     3,
+				QPS:             5,
+			},
+			{
+				SubsiteID:       "idle",
+				Name:            "Idle",
+				Status:          SubsiteStatusActive,
+				HealthScore:     100,
+				LastHeartbeatAt: &now,
+			},
+		}},
+		&autoDistributionAccountRepoStub{accounts: []Account{
+			{ID: 1, Platform: PlatformOpenAI, Status: StatusActive, Schedulable: true, GroupIDs: []int64{10}, Groups: []*Group{group}},
+			{ID: 2, Platform: PlatformOpenAI, Status: StatusActive, Schedulable: true, GroupIDs: []int64{10}, Groups: []*Group{group}},
+		}},
+		nil,
+	)
+
+	result, err := svc.AutoDistribute(context.Background(), AutoDistributeAccountLeasesInput{
+		GroupID:    10,
+		Platform:   PlatformOpenAI,
+		Limit:      2,
+		TTLSeconds: 3600,
+	})
+
+	require.NoError(t, err)
+	require.Equal(t, int64(2), result.Assigned)
+	require.Equal(t, int64(1), result.ExpiredLeases)
+	require.Equal(t, int64(2), result.ReleasedInvalidLeases)
+	require.Len(t, leaseRepo.created, 2)
+	require.Equal(t, "idle", leaseRepo.created[0].SubsiteID)
+	require.Equal(t, "idle", leaseRepo.created[1].SubsiteID)
+}
