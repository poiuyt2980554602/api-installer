+type autoDistributeTarget struct {
+	Stat          SubsiteForwardSiteStat
+	ActiveLeases  int
+	PlannedLeases int
+	LoadScore     float64
+}
+
+func normalizeAutoDistributeLimit(limit int) int {
+	if limit < 0 {
+		return 0
+	}
+	if limit > 1000 {
+		return 1000
+	}
+	return limit
+}
+
+func normalizeAutoDistributeTTL(ttlSeconds int) time.Duration {
+	if ttlSeconds <= 0 {
+		return 24 * time.Hour
+	}
+	if ttlSeconds < 300 {
+		ttlSeconds = 300
+	}
+	if ttlSeconds > 30*24*3600 {
+		ttlSeconds = 30 * 24 * 3600
+	}
+	return time.Duration(ttlSeconds) * time.Second
+}
+
+func normalizeSubsiteIDSet(values []string) map[string]struct{} {
+	out := make(map[string]struct{}, len(values))
+	for _, value := range values {
+		value = strings.TrimSpace(value)
+		if value != "" {
+			out[value] = struct{}{}
+		}
+	}
+	return out
+}
+
+func isAutoDistributeSubsiteHealthy(stat SubsiteForwardSiteStat, includeUnhealthy bool) bool {
+	if includeUnhealthy {
+		return stat.Status != SubsiteStatusDisabled && stat.Status != SubsiteStatusMaintenance
+	}
+	if stat.Status != SubsiteStatusActive {
+		return false
+	}
+	if stat.CircuitOpen {
+		return false
+	}
+	if stat.HealthScore < 50 {
+		return false
+	}
+	if stat.LastHeartbeatAt == nil {
+		return false
+	}
+	return time.Since(*stat.LastHeartbeatAt) <= 3*time.Minute
+}
+
+func autoDistributeLoadScore(target *autoDistributeTarget) float64 {
+	if target == nil {
+		return math.MaxFloat64
+	}
+	stat := target.Stat
+	score := float64(target.ActiveLeases+target.PlannedLeases) * 10
+	score += float64(stat.ActiveRequests) * 3
+	score += float64(stat.QueuedUsage) * 2
+	score += stat.QPS * 2
+	if stat.CPUPercent > 0 {
+		score += stat.CPUPercent / 20
+	}
+	if stat.Events24h > 0 {
+		score += float64(stat.Failures24h) / float64(stat.Events24h) * 50
+	}
+	if stat.HealthScore < 100 {
+		score += float64(100-stat.HealthScore) / 5
+	}
+	if stat.CircuitOpen {
+		score += 1000
+	}
+	return score
+}
+
+func subsiteLoadLevel(stat SubsiteForwardSiteStat) string {
+	if stat.CircuitOpen || stat.HealthScore < 50 {
+		return "blocked"
+	}
+	if stat.CPUPercent >= 90 || stat.QueuedUsage >= 20 || stat.ActiveRequests >= 50 {
+		return "critical"
+	}
+	if stat.CPUPercent >= 75 || stat.QueuedUsage >= 10 || stat.ActiveRequests >= 20 {
+		return "busy"
+	}
+	if stat.CPUPercent >= 50 || stat.QueuedUsage >= 3 || stat.ActiveRequests >= 8 || stat.QPS >= 5 {
+		return "warm"
+	}
+	return "idle"
+}
+
+func SubsiteLoadLevelForStats(stat SubsiteForwardSiteStat) string {
+	return subsiteLoadLevel(stat)
+}
+
+func subsiteEffectiveStatus(stat SubsiteForwardSiteStat, now time.Time) string {
+	switch stat.Status {
+	case SubsiteStatusDisabled, SubsiteStatusMaintenance:
+		return stat.Status
+	}
+	if stat.LastHeartbeatAt == nil || now.Sub(*stat.LastHeartbeatAt) > 3*time.Minute {
+		return SubsiteStatusUnhealthy
+	}
+	if stat.CircuitOpen || stat.HealthScore < 50 {
+		return SubsiteStatusUnhealthy
+	}
+	return SubsiteStatusActive
+}
+
+func SubsiteEffectiveStatusForStats(stat SubsiteForwardSiteStat, now time.Time) string {
+	return subsiteEffectiveStatus(stat, now)
+}
+
+func pickLeastLoadedSubsite(targets []*autoDistributeTarget) *autoDistributeTarget {
+	var selected *autoDistributeTarget
+	selectedScore := math.MaxFloat64
+	for _, target := range targets {
+		score := autoDistributeLoadScore(target)
+		if selected == nil || score < selectedScore || (score == selectedScore && target.Stat.SubsiteID < selected.Stat.SubsiteID) {
+			selected = target
+			selectedScore = score
+		}
+	}
+	return selected
+}
