+func (r *accountLeaseRepository) ReleaseInvalid(ctx context.Context, reason string) (int64, error) {
+	reason = strings.TrimSpace(reason)
+	if reason == "" {
+		reason = "account unavailable for scheduling"
+	}
+	var released int64
+	err := r.db.QueryRowContext(ctx, `
+		WITH invalid_leases AS (
+			SELECT al.lease_id, al.account_id
+			FROM account_leases al
+			JOIN accounts a ON a.id = al.account_id
+			LEFT JOIN groups g ON g.id = al.group_id AND g.deleted_at IS NULL
+			WHERE al.deleted_at IS NULL
+			  AND al.status IN ('active', 'renewing', 'draining')
+			  AND (
+				  a.deleted_at IS NOT NULL
+				  OR a.status <> 'active'
+				  OR a.schedulable = FALSE
+				  OR (a.auto_pause_on_expired = TRUE AND a.expires_at IS NOT NULL AND a.expires_at <= NOW())
+				  OR g.id IS NULL
+				  OR g.status <> 'active'
+				  OR (g.platform <> '' AND a.platform <> '' AND g.platform <> a.platform)
+				  OR (
+					  g.platform = 'openai'
+					  AND a.platform = 'openai'
+					  AND COALESCE(g.scope, 'public') = 'public'
+					  AND COALESCE(g.required_account_level, '') IN ('free', 'plus', 'pro')
+					  AND COALESCE(a.account_level, 'unknown') IN ('unknown', 'free', 'plus', 'pro', 'team')
+					  AND COALESCE(a.account_level, 'unknown') <> COALESCE(g.required_account_level, '')
+				  )
+				  OR (
+					  COALESCE(g.scope, 'public') = 'public'
+					  AND a.owner_user_id IS NOT NULL
+					  AND (
+						  COALESCE(a.share_mode, 'private') <> 'public'
+						  OR COALESCE(a.share_status, 'approved') <> 'approved'
+					  )
+				  )
+			  )
+		),
+		released AS (
+			UPDATE account_leases al
+			SET status = 'released',
+				released_at = COALESCE(released_at, NOW()),
+				updated_at = NOW()
+			FROM invalid_leases il
+			WHERE al.lease_id = il.lease_id
+			RETURNING al.lease_id, al.account_id
+		),
+		cleared_affinities AS (
+			UPDATE subsite_forward_affinities fa
+			SET deleted_at = NOW(),
+				updated_at = NOW(),
+				last_error = $1
+			FROM released r
+			WHERE fa.deleted_at IS NULL
+			  AND (
+				  fa.lease_id = r.lease_id
+				  OR fa.account_id = r.account_id
+			  )
+			RETURNING fa.id
+		)
+		SELECT COUNT(*) FROM released
+	`, reason).Scan(&released)
+	if err != nil {
+		return 0, fmt.Errorf("release invalid account leases: %w", err)
+	}
+	return released, nil
+}
