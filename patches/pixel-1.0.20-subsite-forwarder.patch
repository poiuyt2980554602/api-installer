+}
+
+func isSubsiteAccountCompatibleWithGroupRequest(account *Account, group *Group, requestedModel string) bool {
+	if account == nil {
+		return false
+	}
+	model := subsiteGroupModelForAccountCheck(group, requestedModel)
+	if model != "" && !account.IsModelSupported(model) {
+		return false
+	}
+	if group == nil {
+		return true
+	}
+	if group.Platform != "" && account.Platform != "" && !strings.EqualFold(group.Platform, account.Platform) {
+		return false
+	}
+	if requiresSubsiteOpenAISharedPoolLevelMatch(account, group) {
+		requiredLevel := NormalizeRequiredAccountLevel(group.RequiredAccountLevel)
+		if requiredLevel != "" && !openAIAccountMeetsSubsiteRequiredLevel(account, requiredLevel) {
+			return false
+		}
+	}
+	return true
+}
+
+func requiresSubsiteOpenAISharedPoolLevelMatch(account *Account, group *Group) bool {
+	if account == nil || group == nil {
+		return false
+	}
+	if account.Platform != PlatformOpenAI {
+		return false
+	}
+	if group.Platform != "" && group.Platform != PlatformOpenAI {
+		return false
+	}
+	if group.OwnerUserID != nil || NormalizeGroupScope(group.Scope) != GroupScopePublic {
+		return false
+	}
+	return account.IsPublicShareApproved() || account.OwnerUserID == nil
+}
+
+func subsiteGroupModelForAccountCheck(group *Group, requestedModel string) string {
+	requestedModel = strings.TrimSpace(requestedModel)
+	if group != nil && group.Platform == PlatformOpenAI {
+		if mapped := strings.TrimSpace(group.ResolveMessagesDispatchModel(requestedModel)); mapped != "" {
+			return mapped
+		}
+	}
+	return requestedModel
+}
+
+func openAIAccountMeetsSubsiteRequiredLevel(account *Account, requiredLevel string) bool {
+	requiredLevel = NormalizeRequiredAccountLevel(requiredLevel)
+	if requiredLevel == "" {
+		return true
+	}
+	if account == nil {
+		return false
+	}
+	accountLevel := NormalizeOpenAIAccountLevel(account.Platform, account.AccountLevel, account.Credentials, account.Extra)
+	return NormalizeAccountLevel(accountLevel) == requiredLevel
+}
