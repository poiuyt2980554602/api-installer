+			COALESCE((SELECT SUM(ul.input_tokens + ul.cache_read_tokens) FROM usage_logs ul JOIN quota_reservations qr ON qr.request_id = ul.request_id WHERE ul.created_at >= NOW() - INTERVAL '24 hours'), 0)
