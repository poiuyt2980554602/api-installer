+func prepareStreamingResponse(c *gin.Context, statusCode int, contentType string) {
+	if contentType == "" {
+		contentType = "text/event-stream"
+	}
+	header := c.Writer.Header()
+	header.Set("Content-Type", contentType)
+	header.Set("Cache-Control", "no-cache")
+	header.Set("X-Accel-Buffering", "no")
+	header.Del("Content-Length")
+	c.Status(statusCode)
+	c.Writer.WriteHeaderNow()
+	c.Writer.Flush()
+}
+
+func streamRawResponseBody(c *gin.Context, reader io.Reader, statusCode int, contentType string, metrics *responseCaptureMetrics) ([]byte, error) {
+	prepareStreamingResponse(c, statusCode, contentType)
+	startedAt := time.Now()
+	var out bytes.Buffer
+	chunk := make([]byte, 32*1024)
+	var pendingSSE []byte
+	truncated := false
+	for {
+		n, err := reader.Read(chunk)
+		if n > 0 {
+			part := chunk[:n]
+			if !truncated {
+				if out.Len()+n <= maxBufferedUpstreamBody {
+					_, _ = out.Write(part)
+				} else {
+					truncated = true
+				}
+			}
+			if isSSEContentType(contentType) && metrics != nil && metrics.firstTokenMs == nil {
+				pendingSSE = append(pendingSSE, part...)
+				pendingSSE = observeSSEFirstToken(pendingSSE, startedAt, metrics)
+			}
+			if _, writeErr := c.Writer.Write(part); writeErr != nil {
+				return out.Bytes(), writeErr
+			}
+			c.Writer.Flush()
+		}
+		if err != nil {
+			if err == io.EOF {
+				break
+			}
+			return out.Bytes(), err
+		}
+	}
+	if isSSEContentType(contentType) && metrics != nil && metrics.firstTokenMs == nil && len(pendingSSE) > 0 {
+		_ = observeSSELine(bytes.TrimRight(pendingSSE, "\r"), startedAt, metrics)
+	}
+	return out.Bytes(), nil
+}
+
+func streamResponsesSSEToChatCompletions(c *gin.Context, resp *http.Response, originalModel string) ([]byte, *responseCaptureMetrics, error) {
+	copyResponseHeaders(c.Writer.Header(), resp.Header)
+	prepareStreamingResponse(c, resp.StatusCode, "text/event-stream")
+
+	startedAt := time.Now()
+	metrics := &responseCaptureMetrics{}
+	state := apicompat.NewResponsesEventToChatState()
+	state.Model = originalModel
+	reader := bufio.NewReader(resp.Body)
+	var upstreamBody bytes.Buffer
+	truncated := false
+
+	for {
+		line, err := reader.ReadBytes('\n')
+		if len(line) > 0 {
+			if !truncated {
+				if upstreamBody.Len()+len(line) <= maxBufferedUpstreamBody {
+					_, _ = upstreamBody.Write(line)
+				} else {
+					truncated = true
+				}
+			}
+			_ = observeSSELine(bytes.TrimRight(line, "\r\n"), startedAt, metrics)
+			if err := writeConvertedResponsesSSELine(c, bytes.TrimRight(line, "\r\n"), state); err != nil {
+				return upstreamBody.Bytes(), metrics, err
+			}
+		}
+		if err != nil {
+			if err == io.EOF {
+				break
+			}
+			return upstreamBody.Bytes(), metrics, fmt.Errorf("read responses sse: %w", err)
+		}
+	}
+	for _, chunk := range apicompat.FinalizeResponsesChatStream(state) {
+		sse, err := apicompat.ChatChunkToSSE(chunk)
+		if err != nil {
+			return upstreamBody.Bytes(), metrics, fmt.Errorf("finalize chat chunk: %w", err)
+		}
+		if _, err := c.Writer.Write([]byte(sse)); err != nil {
+			return upstreamBody.Bytes(), metrics, err
+		}
+		c.Writer.Flush()
+	}
+	if _, err := c.Writer.Write([]byte("data: [DONE]\n\n")); err != nil {
+		return upstreamBody.Bytes(), metrics, err
+	}
+	c.Writer.Flush()
+	return upstreamBody.Bytes(), metrics, nil
+}
+
+func writeConvertedResponsesSSELine(c *gin.Context, rawLine []byte, state *apicompat.ResponsesEventToChatState) error {
+	line := string(rawLine)
+	if !strings.HasPrefix(line, "data: ") || line == "data: [DONE]" {
+		return nil
+	}
+	var event apicompat.ResponsesStreamEvent
+	if err := json.Unmarshal([]byte(line[6:]), &event); err != nil {
+		return fmt.Errorf("parse responses sse event: %w", err)
+	}
+	for _, chunk := range apicompat.ResponsesEventToChatChunks(&event, state) {
+		sse, err := apicompat.ChatChunkToSSE(chunk)
+		if err != nil {
+			return fmt.Errorf("marshal chat chunk: %w", err)
+		}
+		if _, err := c.Writer.Write([]byte(sse)); err != nil {
+			return err
+		}
+		c.Writer.Flush()
+	}
+	return nil
+}
