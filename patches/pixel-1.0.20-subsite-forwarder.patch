+func autoDistributeUnschedulableReason(account *Account, now time.Time) string {
+	if account == nil {
+		return "account_missing"
+	}
+	if !account.IsActive() {
+		return "account_" + strings.TrimSpace(account.Status)
+	}
+	if !account.Schedulable {
+		return "manual_unschedulable"
+	}
+	if account.AutoPauseOnExpired && account.ExpiresAt != nil && !now.Before(*account.ExpiresAt) {
+		return "account_expired"
+	}
+	if account.OverloadUntil != nil && now.Before(*account.OverloadUntil) {
+		return "overloaded"
+	}
+	if account.RateLimitResetAt != nil && now.Before(*account.RateLimitResetAt) {
+		return "rate_limited"
+	}
+	if account.TempUnschedulableUntil != nil && now.Before(*account.TempUnschedulableUntil) {
+		if reason := strings.TrimSpace(account.TempUnschedulableReason); reason != "" {
+			return reason
+		}
+		return "temporary_unschedulable"
+	}
+	if account.IsCodexQuotaProtectionActiveAt(now) {
+		return "codex_quota_protected"
+	}
+	if account.IsAPIKeyOrBedrock() && account.IsQuotaExceededAt(now) {
+		return "quota_exceeded"
+	}
+	return "not_schedulable"
+}
+
+func autoDistributeLimitedUntil(account *Account, now time.Time) *time.Time {
+	if account == nil {
+		return nil
+	}
+	candidates := []*time.Time{
+		account.RateLimitResetAt,
+		account.OverloadUntil,
+		account.TempUnschedulableUntil,
+	}
+	for _, item := range candidates {
+		if item != nil && now.Before(*item) {
+			return item
+		}
+	}
+	return nil
+}
