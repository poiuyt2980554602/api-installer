+func (s *AccountLeaseService) autoDistributeTargets(ctx context.Context, input AutoDistributeAccountLeasesInput) ([]*autoDistributeTarget, error) {
+	stats, ok := s.subsiteRepo.(SubsiteForwardRepository)
+	if !ok {
+		return nil, errors.New("subsite forward stats repository is unavailable")
+	}
+	routeStats, err := stats.ForwardRouteStats(ctx)
+	if err != nil {
+		return nil, err
+	}
+	allowedSubsites := normalizeSubsiteIDSet(input.SubsiteIDs)
+	targets := make([]*autoDistributeTarget, 0, len(routeStats))
+	for i := range routeStats {
+		stat := routeStats[i]
+		if len(allowedSubsites) > 0 {
+			if _, ok := allowedSubsites[stat.SubsiteID]; !ok {
+				continue
+			}
+		}
+		if !isAutoDistributeSubsiteHealthy(stat, input.IncludeUnhealthy) {
+			continue
+		}
+		stat.EffectiveStatus = subsiteEffectiveStatus(stat, time.Now())
+		stat.LoadLevel = subsiteLoadLevel(stat)
+		activeLeases, err := s.leaseRepo.ListActiveBySubsite(ctx, stat.SubsiteID)
+		if err != nil {
+			return nil, err
+		}
+		target := &autoDistributeTarget{
+			Stat:         stat,
+			ActiveLeases: len(activeLeases),
+		}
+		target.LoadScore = autoDistributeLoadScore(target)
+		targets = append(targets, target)
+	}
+	sort.SliceStable(targets, func(i, j int) bool {
+		if targets[i].LoadScore == targets[j].LoadScore {
+			return targets[i].Stat.SubsiteID < targets[j].Stat.SubsiteID
+		}
+		return targets[i].LoadScore < targets[j].LoadScore
+	})
+	return targets, nil
+}
+
+func (s *AccountLeaseService) autoDistributeAccounts(ctx context.Context, input AutoDistributeAccountLeasesInput) ([]Account, error) {
+	platform := strings.TrimSpace(input.Platform)
+	switch {
+	case input.GroupID > 0 && platform != "":
+		return s.accountRepo.ListSchedulableByGroupIDAndPlatform(ctx, input.GroupID, platform)
+	case input.GroupID > 0:
+		return s.accountRepo.ListSchedulableByGroupID(ctx, input.GroupID)
+	case platform != "":
+		return s.accountRepo.ListSchedulableByPlatform(ctx, platform)
+	default:
+		return s.accountRepo.ListSchedulable(ctx)
+	}
+}
