+		released, err := s.leaseRepo.ReleaseInvalid(ctx, "account unavailable for scheduling")
+		if err != nil {
+			return nil, err
+		}
+		result.ReleasedInvalidLeases = released
+	}
+
+	targets, err := s.autoDistributeTargets(ctx, input)
+	if err != nil {
+		return nil, err
+	}
+	result.TargetSubsites = int64(len(targets))
+	for _, target := range targets {
+		result.BySubsite = append(result.BySubsite, AutoDistributeSubsiteResult{
+			SubsiteID:      target.Stat.SubsiteID,
+			Name:           target.Stat.Name,
+			ActiveLeases:   int64(target.ActiveLeases),
+			LoadScore:      target.LoadScore,
+			LoadLevel:      target.Stat.LoadLevel,
+			HealthScore:    target.Stat.HealthScore,
+			ActiveRequests: target.Stat.ActiveRequests,
+			QueuedUsage:    target.Stat.QueuedUsage,
