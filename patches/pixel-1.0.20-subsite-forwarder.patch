+		return groupID, true
+	}
+	if s == nil || s.groupRepo == nil || account == nil {
+		return 0, false
+	}
+	platform := strings.TrimSpace(preferredPlatform)
+	if preferredGroupID > 0 {
+		if len(account.GroupIDs) > 0 && !containsInt64(account.GroupIDs, preferredGroupID) {
+			return 0, false
+		}
+		group, err := s.groupRepo.GetByID(ctx, preferredGroupID)
+		if err != nil || group == nil {
+			return 0, false
+		}
+		if isAutoDistributePublicGroup(account, group, platform) &&
+			isSubsiteAccountCompatibleWithGroupRequest(account, group, "") {
+			return group.ID, true
+		}
+		return 0, false
+	}
+	for _, groupID := range account.GroupIDs {
+		if groupID <= 0 {
+			continue
+		}
+		group, err := s.groupRepo.GetByID(ctx, groupID)
+		if err != nil || group == nil {
+			continue
+		}
+		if isAutoDistributePublicGroup(account, group, platform) &&
+			isSubsiteAccountCompatibleWithGroupRequest(account, group, "") {
+			return group.ID, true
+		}
+	}
+	return 0, false
+}
