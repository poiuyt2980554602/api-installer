+function decodeBase64UrlUtf8(value: string): string {
+  const normalized = value.replace(/-/g, '+').replace(/_/g, '/')
+  const padded = normalized.padEnd(Math.ceil(normalized.length / 4) * 4, '=')
+  const binary = atob(padded)
+  const bytes = Uint8Array.from(binary, (char) => char.charCodeAt(0))
+  return new TextDecoder().decode(bytes)
+}
+
+function getPixelImportPayload(hash: string): Record<string, unknown> | null {
+  const route = hash.trim().replace(/^#/, '')
+  if (!route.startsWith(PIXEL_IMPORT_HASH_PATH)) return null
+
+  const queryIndex = route.indexOf('?')
+  if (queryIndex < 0) return null
+
+  const payload = new URLSearchParams(route.slice(queryIndex + 1)).get('payload')
+  if (!payload) return null
+
+  try {
+    const parsed = JSON.parse(decodeBase64UrlUtf8(payload))
+    if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) return null
+    return parsed as Record<string, unknown>
+  } catch {
+    return null
+  }
+}
+
+function getPixelImportProfileName(payload: Record<string, unknown>): string {
+  const sourceName = typeof payload.sourceName === 'string' ? payload.sourceName.trim() : ''
+  const keyName = typeof payload.keyName === 'string' ? payload.keyName.trim() : ''
+  return [sourceName, keyName].filter(Boolean).join(' - ') || 'Pixel API'
+}
+
+export function hasPixelImportHash(hash: string): boolean {
+  return getPixelImportPayload(hash) !== null
+}
+
+export function buildUrlSettingParamsFromLocation(location: Pick<Location, 'search' | 'hash'>): URLSearchParams {
+  const searchParams = new URLSearchParams(location.search)
+  const pixelPayload = getPixelImportPayload(location.hash)
+  if (!pixelPayload) return searchParams
+
+  const apiBaseUrl = typeof pixelPayload.apiBaseUrl === 'string' ? pixelPayload.apiBaseUrl.trim() : ''
+  const apiKey = typeof pixelPayload.apiKey === 'string' ? pixelPayload.apiKey.trim() : ''
+  const model = typeof pixelPayload.model === 'string' ? pixelPayload.model.trim() : ''
+  if (apiBaseUrl) searchParams.set('apiUrl', apiBaseUrl)
+  if (apiKey) searchParams.set('apiKey', apiKey)
+  if (model) searchParams.set('model', model)
+  searchParams.set('apiMode', 'images')
+  searchParams.set('profileName', getPixelImportProfileName(pixelPayload))
+
+  return searchParams
+}
